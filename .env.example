# Lokaal dev: Vite leest dit niet automatisch in voor Pages Functions.
# Voor lokaal: maak .dev.vars (Wrangler) met dezelfde keys.
# Productie (Cloudflare Pages): zet ze als Environment variables / Secrets,
# bv. via `wrangler pages secret put <NAAM>` of in het Cloudflare dashboard.

# Gemini (optioneel - zonder key valt /api/gemini/optimize terug op een mock)
GEMINI_API_KEY=

# --- Google OAuth (GA4 + Search Console) --- zie OAUTH_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vast basis-domein voor OAuth redirect-URI's (GEEN per-deploy hash-subdomein).
# Laat leeg om de origin van het request te gebruiken; voor productie aanbevolen:
# APP_BASE_URL=https://publisher-dashboard.pages.dev
APP_BASE_URL=
