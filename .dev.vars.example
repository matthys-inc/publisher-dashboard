# Wrangler leest .dev.vars in voor `wrangler pages dev`.
# Kopieer naar .dev.vars (niet in git) en vul jouw waarden in.

GEMINI_API_KEY=

# Google OAuth (zie OAUTH_SETUP.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Voor lokaal testen van de OAuth-callback, bv:
# APP_BASE_URL=http://localhost:8788
APP_BASE_URL=

# --- Inlogmuur ---
# Geheim om de sessie-cookie te ondertekenen. Genereer iets willekeurigs, bv.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Komma-gescheiden lijst van e-mailadressen die mogen inloggen.
ALLOWED_EMAILS=sm.vanderv33n@gmail.com, info@nordwaartszweden.nl
